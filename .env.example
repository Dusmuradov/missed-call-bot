# Токен бота от @BotFather
BOT_TOKEN=123456:ABCDefGhIJKlmNoPQRsTUVwxyZ

# ID группы операторов (отрицательный для супергрупп/каналов)
TELEGRAM_CHAT_ID=-1001234567890

# ID темы внутри супергруппы (оставьте пустым если тем нет)
TELEGRAM_THREAD_ID=

# Whitelist user_id для доступа к отчётам (через запятую, пустой = все)
# Получить свой ID: написать @userinfobot
REPORT_ALLOWED_USERS=

# Секрет, который Utel шлёт в заголовке каждого webhook-запроса
WEBHOOK_SECRET=замените_на_длинную_случайную_строку

# Имя HTTP-заголовка с секретом (уточните у поддержки Utel)
WEBHOOK_SECRET_HEADER=X-Webhook-Secret

# Таймзона для отображения времени звонков
TIMEZONE=Asia/Tashkent

# Уровень логирования: DEBUG | INFO | WARNING | ERROR
# Включите DEBUG чтобы увидеть Raw webhook payload и найти поле оператора
LOG_LEVEL=INFO

# ---------------------------------------------------------
# База данных (SQLite по умолчанию, Railway Postgres позже)
# ---------------------------------------------------------
# DATABASE_URL=sqlite+aiosqlite:///./data/calls.db
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname
DATABASE_URL=

# ---------------------------------------------------------
# Планировщик перезвонов
# ---------------------------------------------------------
# Через сколько минут считать пропущенный звонок "не перезвоненным"
CALLBACK_CHECK_MINUTES=10

# ---------------------------------------------------------
# Операторы (JSON-маппинг extension → имя)
# ---------------------------------------------------------
# OPERATORS_MAP={"101": "Азиз", "102": "Камола", "103": "Санжар"}
OPERATORS_MAP=

# ---------------------------------------------------------
# AmoCRM (один аккаунт)
# ---------------------------------------------------------
# Поддомен: yourcompany.amocrm.ru → AMOCRM_SUBDOMAIN=yourcompany
AMOCRM_SUBDOMAIN=
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=https://your-app.railway.app/amocrm/oauth/callback
# ID первого (входящего) статуса воронки. Оставьте 0 чтобы определять автоматически.
AMOCRM_INITIAL_STATUS_ID=0
